# ── Database ──────────────────────────────────────────────────────────────────
# DB_TYPE: "sqlite" (default) or "postgres"
# DB_TYPE=sqlite

# SQLite: path to the data directory (default: ./data)
# DATA_DIR=./data

# PostgreSQL: required when DB_TYPE=postgres
# POSTGRES_PASSWORD=change-me-to-a-strong-random-password
# POSTGRES_USER=montly           # optional, defaults to "montly"
# DATABASE_URL=postgres://montly:change-me@localhost:5432/montly

# ── Auth ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET: HMAC signing key for session cookies.
# If unset, a random key is generated each restart (sessions are lost on restart).
# Generate a good value with: openssl rand -base64 32
# SESSION_SECRET=

# ADMIN_USERNAME / ADMIN_PASSWORD: used ONCE on first startup when no users exist.
# After the admin account is created these env vars are ignored.
# ADMIN_PASSWORD must be at least 8 characters — change it before deploying.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-at-least-8-chars

# TRUST_PROXY_HEADERS: set to "true" ONLY when montly is behind a trusted
# reverse proxy (e.g. nginx, Traefik) that sets X-Forwarded-For.
# Leaving this false prevents IP spoofing of the rate limiter.
# TRUST_PROXY_HEADERS=false

# SECURE_COOKIES: set to "true" when serving over HTTPS.
# Adds the Secure flag to session cookies and HSTS header.
# SECURE_COOKIES=true

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=8080
